<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        app:key="CategoryBase"
        app:title="Basic Settings"
        app:iconSpaceReserved="false">

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="true"
            app:key="AutoOpen"
            app:title="Auto Open"
            app:summary="Automatically open app when Android Auto is connected"
            app:iconSpaceReserved="false"/>

        <EditTextPreference
            android:inputType="text"
            app:singleLineTitle="true"
            app:defaultValue="com.autonavi.amapauto"
            app:key="LauncherPackage"
            app:title="Default Launch Package"
            app:summary="Package name of the app to launch when virtual display is created, can be empty"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false"/>

        <EditTextPreference
            android:inputType="text"
            app:singleLineTitle="true"
            app:defaultValue="com.ss.squarehome2"
            app:key="HomePackage"
            app:title="Home Package"
            app:summary="Package name of the app to launch when Home key is pressed"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false"/>

        <EditTextPreference
            android:inputType="number"
            app:key="AndroidAutoDpi"
            app:title="Android Auto DPI (0 = keep default)"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:inputType="number"
            app:key="VirtualDisplayDpi"
            app:title="Mirrored Display DPI (0 = keep default)"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:inputType="number"
            app:key="VirtualDisplayWidth"
            app:title="Virtual Display Width (0 = auto)"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:inputType="number"
            app:key="VirtualDisplayHeight"
            app:title="Virtual Display Height (0 = auto)"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <EditTextPreference
            android:inputType="number"
            app:defaultValue="180"
            app:key="DelayDestroyTime"
            app:title="Keep Display Alive After Exit (seconds)"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="true"
            app:key="ScreenOffReplaceLockScreen"
            app:title="Screen Off Only"
            app:summary="Recommended: power key turns off only the phone display, keeping Android Auto input working"
            app:iconSpaceReserved="false"/>

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="true"
            app:key="ScreenOffBlackOverlayFallback"
            app:title="Black Overlay Fallback"
            app:summary="When SurfaceControl display power fails (e.g. Android 17), use a black overlay instead. Keeps AA input working but does not truly turn off the screen."
            app:iconSpaceReserved="false"/>

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="false"
            app:key="DebugInputInjectionLog"
            app:title="Debug Input Injection Log"
            app:summary="Log every touch event through the full pipeline. Enable for troubleshooting, disable for performance."
            app:iconSpaceReserved="false"/>

        <Preference
            app:key="ExportDiagnosticLog"
            app:title="Export Diagnostic Log"
            app:summary="Export captured diagnostic log to file for analysis"
            app:iconSpaceReserved="false"/>

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="true"
            app:key="CloseLauncherDashboard"
            app:title="Block AA Split Screen"
            app:summary="Hide Android Auto's split-screen / dashboard so the mirrored app uses the full screen"
            app:iconSpaceReserved="false"/>

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="true"
            app:key="ForceRightAngle"
            app:title="Force Right Angle"
            app:summary="Square off the projected screen corners (disable rounded corners)"
            app:iconSpaceReserved="false"/>

        <ListPreference
            app:key="DisplayImePolicy"
            app:defaultValue="1"
            app:title="Keyboard (IME) Display"
            app:entries="@array/ime_policy_keys"
            app:entryValues="@array/ime_policy_values"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false"/>

        <EditTextPreference
            android:inputType="text"
            app:singleLineTitle="true"
            app:key="VoiceAssistShell"
            app:title="Voice Assistant Shell"
            app:summary="Root shell command to run on long-press of the assistant key. Empty = use Android Auto's built-in assistant. Example: am start com.miui.voiceassist/com.xiaomi.voiceassistant.CTAAlertActivity"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <PreferenceCategory
        app:key="CategoryShell"
        app:title="Shell Commands"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:inputType="textMultiLine"
            app:key="CreateVirtualDisplayBefore"
            app:title="Execute Before Creating Virtual Display"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false"/>

        <EditTextPreference
            android:inputType="textMultiLine"
            app:key="DestroyVirtualDisplayAfter"
            app:title="Execute After Destroying Virtual Display"
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <PreferenceCategory
        app:key="CategoryAndroidAuto"
        app:title="Advanced (optional)"
        app:summary="Inject extra system properties into Android Auto's processes (one &quot;name=value&quot; per line). Leave blank unless a guide tells you to set something — wrong values can break projection."
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:inputType="textMultiLine"
            app:key="ComGoogleAndroidProjectionGearheadProps"
            app:title="Android Auto app properties"
            app:summary="Injected into com.google.android.projection.gearhead"
            app:iconSpaceReserved="false"/>

        <EditTextPreference
            android:inputType="textMultiLine"
            app:key="ComGoogleAndroidGmsCarProps"
            app:title="Play Services Car properties"
            app:summary="Injected into com.google.android.gms.car"
            app:iconSpaceReserved="false"/>

    </PreferenceCategory>

    <PreferenceCategory
        app:key="CategoryAbout"
        app:title="About"
        app:iconSpaceReserved="false">

        <Preference
            app:key="GithubLink"
            app:title="Source code &amp; updates"
            app:summary="github.com/Masterain98/AADisplay-101"
            app:iconSpaceReserved="false">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/Masterain98/AADisplay-101"/>
        </Preference>

    </PreferenceCategory>

    <PreferenceCategory
        app:key="CategoryCredit"
        app:title="Credit"
        app:iconSpaceReserved="false">

        <Preference
            app:key="UpstreamKoala"
            app:title="koalaauto/AADisplay-Beta"
            app:summary="Direct upstream fork"
            app:iconSpaceReserved="false">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/koalaauto/AADisplay-Beta"/>
        </Preference>

        <Preference
            app:key="UpstreamNitsuya"
            app:title="Nitsuya/AADisplay"
            app:summary="Original project"
            app:iconSpaceReserved="false">
            <intent
                android:action="android.intent.action.VIEW"
                android:data="https://github.com/Nitsuya/AADisplay"/>
        </Preference>

    </PreferenceCategory>

</PreferenceScreen>